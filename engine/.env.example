# ─── Supabase ───────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── Claude API ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Instantly ───────────────────────────────────────────────
INSTANTLY_API_KEY=your-instantly-api-key

# ─── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from your Stripe dashboard — used to detect client tier on checkout
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_SCALE=price_...

# ─── Admin Dashboard ─────────────────────────────────────
ADMIN_PASSWORD=choose-a-strong-password

# ─── Webhook Server ─────────────────────────────────────────
PORT=3000
WEBHOOK_BASE_URL=https://your-domain.com

# ─── Scraping ───────────────────────────────────────────────
# Set to "true" to run Playwright in headless mode (recommended for prod)
PLAYWRIGHT_HEADLESS=true

# ─── Google Maps (optional, for Places API fallback) ────────
GOOGLE_MAPS_API_KEY=your-google-maps-key

# ─── BatchData (B2C skip tracing) ───────────────────────────
BATCH_DATA_API_KEY=your-batchdata-api-key
